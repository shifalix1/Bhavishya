# Google AI Studio API key (required for cloud mode
# Get yours at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_ai_studio_key_here

# Runtime mode 
# cloud ~ uses Gemma 4 26B via Google AI Studio (recommended, no GPU needed)
# ollama ~ uses Gemma 4 E4B via Ollama for fully offline inference
# requires: ollama pull gemma4:e4b  (needs ~8 GB VRAM or unified RAM)
BHAVISHYA_MODE=cloud

# CORS origins
# Comma-separated list of allowed frontend origins.
# Add your Vercel deployment URL here alongside localhost for local dev.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Optional API key guard 
# Set this to require an X-API-Key header on all API calls.
# Leave blank to run unauthenticated (fine for local dev and hackathon demo).
BHAVISHYA_API_KEY=